{
  "name": "learning-automator",
  "version": "1.0.0",
  "private": true,
  "description": "自动刷课工具 - 支持多实例/自动登录/秒课",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "electron:dev": "electron .",
    "pack:mac": "pnpm build && electron-builder --mac",
    "pack:win": "pnpm build && electron-builder --win",
    "pack:all": "pnpm build && electron-builder --mac --win"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "puppeteer-core": "^24.43.1",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "electron": "^39.2.3",
    "electron-builder": "^26.15.3",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "~10.5.0",
    "jiti": "^2.6.1",
    "prettier": "3.6.2",
    "typescript": "~5.9.0",
    "vite": "^5.4.8",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.learningautomator.app",
    "productName": "LearningAutomator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "public/icon.icns"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "LearningAutomator"
    },
    "asarUnpack": [
      "node_modules/puppeteer-core/**"
    ]
  }
}
